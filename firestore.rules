rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Great Animal Race — Firestore v3 schema
    // Deploy: npm run firebase:deploy
    // See FIREBASE.md for verification checklist.
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == resource.data.userId;
    }

    function validStringLength(fieldData, minLen, maxLen) {
      return fieldData is string &&
        fieldData.size() >= minLen &&
        fieldData.size() <= maxLen;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // --- users_v3 ------------------------------------------------

    function isValidProgressionV3(p) {
      return p is map &&
        p.keys().hasOnly(['age', 'xp', 'coins']) &&
        p.age is number && p.age >= 0 && p.age <= 500 &&
        p.xp is number && p.xp >= 0 && p.xp <= 1000000 &&
        p.coins is number && p.coins >= 0 && p.coins <= 10000000;
    }

    function isValidUserV3Write(data) {
      return hasOnlyAllowedFields([
          'selectedAnimalId', 'petName', 'progression',
          'gameProgress', 'unlockedCosmetics', 'equippedCosmetics', 'chests'
        ]) &&
        (!('selectedAnimalId' in data) || validStringLength(data.selectedAnimalId, 1, 20)) &&
        (!('petName' in data) || validStringLength(data.petName, 0, 50)) &&
        (!('progression' in data) || isValidProgressionV3(data.progression)) &&
        (!('gameProgress' in data) || (data.gameProgress is map && data.gameProgress.size() <= 6)) &&
        (!('unlockedCosmetics' in data) || (data.unlockedCosmetics is list && data.unlockedCosmetics.size() <= 200)) &&
        (!('equippedCosmetics' in data) || (data.equippedCosmetics is list && data.equippedCosmetics.size() <= 16)) &&
        (!('chests' in data) || (data.chests is list && data.chests.size() <= 50));
    }

    match /users_v3/{userId} {
      allow read: if isAuthenticated();
      allow delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserV3Write(request.resource.data);
    }

    // --- leaderboards_v3 -----------------------------------------

    function isValidLeaderboardEntryV3(data, expectedGameId) {
      return hasOnlyAllowedFields([
          'userId', 'gameId', 'score', 'stars', 'totalStars',
          'playerName', 'animalId', 'createdAt'
        ]) &&
        data.userId is string && data.userId == request.auth.uid &&
        data.gameId is string && data.gameId == expectedGameId &&
        (!('score' in data) || (data.score is number && data.score >= 0 && data.score <= 1000000)) &&
        (!('stars' in data) || (data.stars is number && data.stars >= 0 && data.stars <= 3)) &&
        (!('totalStars' in data) || (data.totalStars is number && data.totalStars >= 0 && data.totalStars <= 15)) &&
        (!('playerName' in data) || validStringLength(data.playerName, 1, 50)) &&
        (!('animalId' in data) || validStringLength(data.animalId, 1, 20)) &&
        (!('createdAt' in data) || data.createdAt is timestamp);
    }

    match /leaderboards_v3/{gameId}/entries/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        isOwner(userId) &&
        isValidLeaderboardEntryV3(request.resource.data, gameId) &&
        request.resource.data.keys().hasAll(['userId', 'gameId', 'score', 'playerName', 'animalId', 'createdAt']);
      allow update: if isAuthenticated() &&
        isOwner(userId) &&
        uidNotModified() &&
        request.resource.data.gameId == resource.data.gameId &&
        isValidLeaderboardEntryV3(request.resource.data, gameId);
      allow delete: if isOwner(userId);
    }

    // --- Messaging -----------------------------------------------

    function isValidWorldMessage(data) {
      return hasOnlyAllowedFields(['userId', 'petName', 'animalId', 'text', 'createdAt']) &&
        data.keys().hasAll(['userId', 'petName', 'animalId', 'text', 'createdAt']) &&
        data.userId is string && data.userId == request.auth.uid &&
        validStringLength(data.petName, 1, 50) &&
        validStringLength(data.animalId, 1, 20) &&
        validStringLength(data.text, 1, 200) &&
        data.createdAt is timestamp;
    }

    match /chat_world/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidWorldMessage(request.resource.data);
      allow update, delete: if false;
    }

    function isValidConversation(data) {
      return hasOnlyAllowedFields(['participants', 'participantNames', 'participantAnimals', 'lastMessage', 'lastMessageAt', 'lastMessageBy']) &&
        data.keys().hasAll(['participants', 'participantNames', 'participantAnimals', 'lastMessage', 'lastMessageAt', 'lastMessageBy']) &&
        data.participants is list &&
        data.participants.size() == 2 &&
        request.auth.uid in data.participants &&
        data.participantNames is map &&
        data.participantAnimals is map &&
        validStringLength(data.lastMessage, 1, 200) &&
        data.lastMessageAt is timestamp &&
        data.lastMessageBy is string && data.lastMessageBy == request.auth.uid;
    }

    function isValidConversationUpdate(prevData, newData) {
      return hasOnlyAllowedFields(['participants', 'participantNames', 'participantAnimals', 'lastMessage', 'lastMessageAt', 'lastMessageBy']) &&
        newData.participants == prevData.participants &&
        newData.participantNames == prevData.participantNames &&
        newData.participantAnimals == prevData.participantAnimals &&
        validStringLength(newData.lastMessage, 1, 200) &&
        newData.lastMessageAt is timestamp &&
        newData.lastMessageBy is string && newData.lastMessageBy == request.auth.uid;
    }

    match /chat_dms/{conversationId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isValidConversation(request.resource.data);
      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.participants &&
        isValidConversationUpdate(resource.data, request.resource.data);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chat_dms/$(conversationId)).data.participants;
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chat_dms/$(conversationId)).data.participants &&
          hasOnlyAllowedFields(['userId', 'text', 'createdAt']) &&
          request.resource.data.keys().hasAll(['userId', 'text', 'createdAt']) &&
          request.resource.data.userId == request.auth.uid &&
          validStringLength(request.resource.data.text, 1, 200) &&
          request.resource.data.createdAt is timestamp;
        allow update, delete: if false;
      }
    }
  }
}
